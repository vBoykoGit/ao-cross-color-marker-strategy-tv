//@version=6

// commission_value требует const float — задаётся здесь (0 = без комиссии).
// Изменить комиссию можно через вкладку Properties в настройках стратегии на графике.
strategy("AO Single Bar Strategy", overlay = true, pyramiding = 0,
     default_qty_type  = strategy.fixed,
     default_qty_value = 1,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.0,
     slippage          = 1,
     calc_on_every_tick = false)

// ─────────────────────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────────────────────
avgPosSource   = input.source(close, "Avg Positive AO",
     tooltip = "Подключить плот 'Avg Positive AO' (зелёная линия) из индикатора AO Cross & Color Markers")
avgNegSource   = input.source(close, "Avg Negative AO",
     tooltip = "Подключить плот 'Avg Negative AO' (красная линия) из индикатора AO Cross & Color Markers")
ma34Len        = input.int(34, "MA Exit Length", minval = 1,
     tooltip = "Период скользящей средней для выхода из позиции (синяя линия)")
ma34SrcType    = input.string("Close", "MA Source",
     options  = ["Open", "High", "Low", "Close", "HL/2 — Median", "HLC/3 — Typical", "OHLC/4 — Average"],
     tooltip  = "Ценовой ряд для расчёта скользящей средней выхода")
maxPendingBars = input.int(10, "Макс. баров ожидания ордера", minval = 1,
     tooltip = "Отменить отложенный ордер, если он не исполнился за указанное количество баров")
stopLookback   = input.int(5,  "Lookback баров для стопа", minval = 1,
     tooltip = "Стоп фиксируется в момент исполнения ордера: максимальный High (для Sell) или минимальный Low (для Buy) за последние N баров от бара входа")
riskAmount     = input.float(1000.0, "Риск на сделку ($)", minval = 0.01,
     tooltip = "Фиксированный риск в долларах на каждую сделку. Размер позиции = Риск / |Вход − Стоп|. Игнорируется если включён «Статичный лот».")
useStaticLot   = input.bool(false, "Статичный лот",
     tooltip = "Если включено — фиксированный лот для основных сделок. При активной лесенке лот удваивается на каждом шаге (1x, 2x, 4x, 8x). Расчёт риска по riskAmount игнорируется.")
staticLotSize  = input.float(1.0, "Размер лота", minval = 0.000001,
     tooltip = "Фиксированный размер позиции в контрактах/лотах (активен только при включённом «Статичный лот»).")
maxHoldBars    = input.int(20, "Макс. баров держания позиции", minval = 1,
     tooltip = "Закрыть позицию по рынку если прошло N баров и текущий P&L >= 0 (в нуле или в плюсе)")

// ── Лесенка ──
ladderMaxSteps = input.int(4, "Шагов лесенки (0 = выкл)", group = "Лесенка",
     minval = 0, maxval = 4,
     tooltip = "Максимальное количество шагов лесенки для основных сделок. 0 = выключено.\nРиск шага N = riskAmount + накопленная прибыль шагов 1..N−1.\nПосле SL или после maxSteps побед подряд — лесенка сбрасывается на шаг 1.\nНа разворотные сделки не влияет.")

// ── Переворот ──
enableReversal  = input.bool(false, "Включить стратегию «Переворот»", group = "Переворот",
     tooltip = "При срабатывании стоп-лосса открывать противоположную сделку по рынку")
revLookback     = input.int(10, "Lookback баров для стопа переворота", group = "Переворот", minval = 1,
     tooltip = "Стоп переворота = lowest(low, N) для покупки / highest(high, N) для продажи. Вычисляется однократно в момент срабатывания основного SL.")
revRiskAmount   = input.float(1000.0, "Риск на разворотную сделку ($)", group = "Переворот", minval = 0.01,
     tooltip = "Фиксированный риск в долларах для разворотной сделки. Размер позиции = Риск / |Вход − Стоп|")
revMaxHoldBars  = input.int(50, "Макс. баров держания разворота", group = "Переворот", minval = 1,
     tooltip = "Закрыть разворотную сделку по рынку если она не достигла TP/SL за N баров")

// ─────────────────────────────────────────────────────────────────────────────
// AO Calculation  (идентично индикатору AO Cross & Color Markers)
// ao[2] — сигнальный столбец (offset = -2 как в plotshape индикатора)
// ─────────────────────────────────────────────────────────────────────────────
ao = ta.sma(hl2, 5) - ta.sma(hl2, 34)

// ─────────────────────────────────────────────────────────────────────────────
// Single Bar Pattern
// Три последних закрытых бара AO: colorPrevPrev, colorPrev (одиночный), colorNow
// Паттерн: средний бар иного цвета, крайние одинакового цвета
// ─────────────────────────────────────────────────────────────────────────────
colorNow      = ao[1] > ao[2] ? 1 : ao[1] < ao[2] ? -1 : 0
colorPrev     = ao[2] > ao[3] ? 1 : ao[2] < ao[3] ? -1 : 0
colorPrevPrev = ao[3] > ao[4] ? 1 : ao[3] < ao[4] ? -1 : 0

singleBar = colorPrevPrev != 0 and colorPrev != 0 and colorNow != 0
         and colorPrev != colorPrevPrev
         and colorPrev != colorNow
         and colorPrevPrev == colorNow

// ─────────────────────────────────────────────────────────────────────────────
// Сигнал: направление определяется ПОЗИЦИЕЙ ao[2] (цвет столбца игнорируется)
//   strongSell — AO выше нуля И выше средней линии положительной зоны → SHORT
//   strongBuy  — AO ниже нуля И ниже средней линии отрицательной зоны → LONG
// Средние берутся напрямую из индикатора AO Cross & Color Markers через source.
// avgPosSource[2] / avgNegSource[2] — значения средних на сигнальном баре.
// ─────────────────────────────────────────────────────────────────────────────
sellSignal = singleBar and ao[2] > 0
buySignal  = singleBar and ao[2] < 0

strongSell = sellSignal and not na(avgPosSource[2]) and ao[2] >= avgPosSource[2]
strongBuy  = buySignal  and not na(avgNegSource[2]) and math.abs(ao[2]) >= math.abs(avgNegSource[2])

// ─────────────────────────────────────────────────────────────────────────────
// MA34 — линия выхода из позиции
// ─────────────────────────────────────────────────────────────────────────────
ma34Src = switch ma34SrcType
    "Open"             => open
    "High"             => high
    "Low"              => low
    "Close"            => close
    "HL/2 — Median"    => hl2
    "HLC/3 — Typical"  => hlc3
    "OHLC/4 — Average" => ohlc4
    => close

ma34 = ta.sma(ma34Src, ma34Len)
plot(ma34, "MA Exit", color = color.blue, linewidth = 2)

// ─────────────────────────────────────────────────────────────────────────────
// Состояние отложенного ордера
// ─────────────────────────────────────────────────────────────────────────────
// Лесенка (объявляем здесь, т.к. используется в блоке трейлинга ниже)
var int   ladderStep      = 1    // текущий шаг (1 = первый)
var float ladderCumProfit = 0.0  // накопленная прибыль предыдущих шагов
var int   prevLadderN     = 0    // счётчик закрытых сделок для лесенки

var bool  pendingSell   = false
var bool  pendingBuy    = false
var float pendingEntry  = na   // цена стоп-ордера (trailing)
var float pendingStop   = na   // стоп-лосс при исполнении
var int   pendingBarIdx = na   // бар, на котором поставлен ордер

// Объявляем здесь, т.к. используется в условии приёма нового сигнала выше блока «Переворот»
var bool  revPending    = false

// Новые сигналы принимаются только если нет ни открытой позиции, ни активного ордера
if strongSell and strategy.position_size == 0 and not pendingSell and not pendingBuy and not revPending
    pendingSell   := true
    pendingEntry  := low[2]
    // Стоп — максимальный High за stopLookback баров, заканчивая сигнальным баром[2]
    pendingStop   := ta.highest(high, stopLookback)[2]
    pendingBarIdx := bar_index

if strongBuy and strategy.position_size == 0 and not pendingSell and not pendingBuy and not revPending
    pendingBuy    := true
    pendingEntry  := high[2]
    // Стоп — минимальный Low за stopLookback баров, заканчивая сигнальным баром[2]
    pendingStop   := ta.lowest(low, stopLookback)[2]
    pendingBarIdx := bar_index

// ─────────────────────────────────────────────────────────────────────────────
// Трейлинг отложенного ордера
// Пока позиция не открыта — каждый бар обновляем ордер до экстремума
// предыдущего закрытого бара. Стоп-лосс всегда соответствует тому же бару.
// ─────────────────────────────────────────────────────────────────────────────
if pendingSell and strategy.position_size == 0
    if bar_index - pendingBarIdx >= maxPendingBars
        // Ордер не исполнился за maxPendingBars баров — отменяем
        pendingSell := false
        strategy.cancel("Sell")
    else
        // Трейлинг к минимуму предыдущего бара (ждём пробой вниз)
        // Стоп оценивается динамически — та же формула, что при фиксации fixedStop на баре входа.
        pendingEntry   := low[1]
        _stopEst        = ta.highest(high, stopLookback)
        if _stopEst <= pendingEntry
            // Стоп ниже или равен цене входа — позиция была бы немедленно остановлена, отменяем
            pendingSell := false
            strategy.cancel("Sell")
        else
            _riskDist  = math.abs(_stopEst - pendingEntry) * syminfo.pointvalue
            _stepRisk  = ladderMaxSteps > 0 ? riskAmount + math.max(0.0, ladderCumProfit) : riskAmount
            _qty       = useStaticLot ?
                 staticLotSize * math.pow(2, ladderMaxSteps > 0 ? ladderStep - 1 : 0) :
                 (_riskDist > 0 ? _stepRisk / _riskDist : 1.0)
            _comment   = ladderMaxSteps > 0 ? "SB Sell S" + str.tostring(ladderStep) : "SB Sell"
            strategy.entry("Sell", strategy.short, stop = pendingEntry, qty = _qty,
                 comment = _comment)

if pendingBuy and strategy.position_size == 0
    if bar_index - pendingBarIdx >= maxPendingBars
        // Ордер не исполнился за maxPendingBars баров — отменяем
        pendingBuy := false
        strategy.cancel("Buy")
    else
        // Трейлинг к максимуму предыдущего бара (ждём пробой вверх)
        // Стоп оценивается динамически — та же формула, что при фиксации fixedStop на баре входа.
        pendingEntry := high[1]
        _stopEst      = ta.lowest(low, stopLookback)
        if pendingEntry <= _stopEst
            // Цена упала ниже структурной поддержки — отменяем ордер
            pendingBuy := false
            strategy.cancel("Buy")
        else
            _riskDist = math.abs(pendingEntry - _stopEst) * syminfo.pointvalue
            _stepRisk = ladderMaxSteps > 0 ? riskAmount + math.max(0.0, ladderCumProfit) : riskAmount
            _qty      = useStaticLot ?
                 staticLotSize * math.pow(2, ladderMaxSteps > 0 ? ladderStep - 1 : 0) :
                 (_riskDist > 0 ? _stepRisk / _riskDist : 1.0)
            _comment  = ladderMaxSteps > 0 ? "SB Buy S" + str.tostring(ladderStep) : "SB Buy"
            strategy.entry("Buy", strategy.long, stop = pendingEntry, qty = _qty,
                 comment = _comment)

// ─────────────────────────────────────────────────────────────────────────────
// После открытия позиции: фиксируем стоп-лосс и ждём MA34
// ─────────────────────────────────────────────────────────────────────────────

// Фиксированный стоп-лосс (устанавливается при исполнении ордера)
var float fixedStop = na

// При переходе из ожидания к позиции — фиксируем стоп на баре входа
if strategy.position_size < 0 and pendingSell
    pendingSell := false
    fixedStop   := ta.highest(high, stopLookback)

if strategy.position_size > 0 and pendingBuy
    pendingBuy := false
    fixedStop  := ta.lowest(low, stopLookback)

// Два раздельных ордера для SL и TP MA34 на одну позицию (OCA — один отменяет другой).
// Разные ID критически важны: детектор разворота ищет exit_id == "SL Sell"/"SL Buy",
// поэтому TP выход должен иметь другой ID, иначе разворот открывался бы после каждого TP.

// 1. Стоп-лосс — фиксированный уровень, ID "SL Sell"/"SL Buy" виден детектору разворота
if strategy.position_size < 0 and not na(fixedStop) and strategy.opentrades > 0
    if strategy.opentrades.entry_id(0) == "Sell"
        strategy.exit("SL Sell", "Sell",
             stop         = fixedStop,
             comment_loss = "SL")

if strategy.position_size > 0 and not na(fixedStop) and strategy.opentrades > 0
    if strategy.opentrades.entry_id(0) == "Buy"
        strategy.exit("SL Buy", "Buy",
             stop         = fixedStop,
             comment_loss = "SL")

// 2. Тейк-профит MA34 — лимитный ордер, ID "TP Sell"/"TP Buy" НЕ виден детектору разворота.
//    limit обновляется каждый бар → точное исполнение по уровню MA34.
//    Profit-zone check: limit = na если MA34 не в зоне прибыли (только стоп активен).
if strategy.position_size < 0 and not na(fixedStop) and strategy.opentrades > 0
    if strategy.opentrades.entry_id(0) == "Sell"
        _ep = strategy.opentrades.entry_price(0)
        strategy.exit("TP Sell", "Sell",
             limit          = ma34 < _ep ? ma34 : na,
             comment_profit = "TP MA34")

if strategy.position_size > 0 and not na(fixedStop) and strategy.opentrades > 0
    if strategy.opentrades.entry_id(0) == "Buy"
        _ep = strategy.opentrades.entry_price(0)
        strategy.exit("TP Buy", "Buy",
             limit          = ma34 > _ep ? ma34 : na,
             comment_profit = "TP MA34")

// Сброс fixedStop при закрытии позиции
if strategy.position_size == 0
    fixedStop := na

// ─────────────────────────────────────────────────────────────────────────────
// Выход по времени: если позиция держится >= maxHoldBars баров и P&L >= 0
// ─────────────────────────────────────────────────────────────────────────────
var int posOpenBar = na

// Фиксируем бар открытия при переходе из нуля в позицию
if strategy.position_size != 0 and strategy.position_size[1] == 0
    posOpenBar := bar_index

// Закрываем по рынку если время вышло и позиция не в убытке
// Разворотные сделки из выхода по времени исключены — они закрываются только по TP/SL
_activeId   = strategy.opentrades > 0 ? strategy.opentrades.entry_id(0) : ""
_isRevTrade = _activeId == "Rev Buy" or _activeId == "Rev Sell"
if strategy.position_size != 0 and not na(posOpenBar) and not _isRevTrade
    if bar_index - posOpenBar >= maxHoldBars and strategy.openprofit >= 0
        strategy.close_all(comment = "Time Exit")
        posOpenBar := na

// Выход по времени для разворотных сделок (независимо от P&L, свой лимит revMaxHoldBars)
if enableReversal and strategy.position_size != 0 and not na(posOpenBar) and _isRevTrade
    if bar_index - posOpenBar >= revMaxHoldBars
        strategy.close_all(comment = "Rev Time Exit")
        posOpenBar := na

// Сброс при закрытии позиции любым другим способом
if strategy.position_size == 0
    posOpenBar := na

// ─────────────────────────────────────────────────────────────────────────────
// Стратегия «Переворот»
// При срабатывании SL основной сделки открываем противоположную сделку по рынку.
// Стоп: highest/lowest за revLookback баров.
// Риск и тейк: по $riskAmount (соотношение 1:1).
// ─────────────────────────────────────────────────────────────────────────────
// revPending объявлен выше (перед блоком приёма сигналов)
var bool  revIsBuy    = false   // направление переворота
var int   prevClosedN = 0       // счётчик закрытых сделок предыдущего бара
var float revSLLevel  = na      // зафиксированный стоп разворота

// Детектируем новую закрытую сделку и проверяем, был ли это SL
if enableReversal and strategy.closedtrades > prevClosedN
    _idx    = strategy.closedtrades - 1
    _exitId = strategy.closedtrades.exit_id(_idx)
    if _exitId == "SL Sell" or _exitId == "SL Buy"
        revIsBuy := _exitId == "SL Sell"   // Sell остановлен → разворот вверх
        revPending := true
        // Структурный стоп фиксируется однократно в момент обнаружения SL
        if revIsBuy
            revSLLevel := ta.lowest(low,  revLookback)
        else
            revSLLevel := ta.highest(high, revLookback)
prevClosedN := strategy.closedtrades

// ─────────────────────────────────────────────────────────────────────────────
// Лесенка: обновляем шаг и накопленную прибыль после каждой основной сделки
// ─────────────────────────────────────────────────────────────────────────────
if ladderMaxSteps > 0 and strategy.closedtrades > prevLadderN
    _idx     = strategy.closedtrades - 1
    _entryId = strategy.closedtrades.entry_id(_idx)
    // Обрабатываем только основные сделки (не разворотные)
    if _entryId == "Sell" or _entryId == "Buy"
        _exitId = strategy.closedtrades.exit_id(_idx)
        if _exitId == "SL Sell" or _exitId == "SL Buy"
            // Стоп-лосс — сброс лесенки на шаг 1
            ladderStep      := 1
            ladderCumProfit := 0.0
        else
            // Выход не по стопу — проверяем прибыль: убыток тоже сбрасывает лесенку
            _profit = strategy.closedtrades.profit(_idx)
            if _profit < 0
                ladderStep      := 1
                ladderCumProfit := 0.0
            else
                ladderCumProfit += _profit
                if ladderStep >= ladderMaxSteps
                    // Достигли максимума шагов — сброс
                    ladderStep      := 1
                    ladderCumProfit := 0.0
                else
                    ladderStep += 1
prevLadderN := strategy.closedtrades

// Открываем переворотный ордер по рынку (на следующем баре после SL)
// Qty пересчитывается по текущему close как оценке цены входа,
// чтобы loss при срабатывании стопа ≈ revRiskAmount
if enableReversal and revPending and strategy.position_size == 0
    if revIsBuy
        _dist   = math.abs(close - revSLLevel) * syminfo.pointvalue
        _revQty = _dist > 0 ? revRiskAmount / _dist : 1.0
        strategy.entry("Rev Buy",  strategy.long,  qty = _revQty, comment = "Rev Buy")
    else
        _dist   = math.abs(revSLLevel - close) * syminfo.pointvalue
        _revQty = _dist > 0 ? revRiskAmount / _dist : 1.0
        strategy.entry("Rev Sell", strategy.short, qty = _revQty, comment = "Rev Sell")
    revPending := false

// Устанавливаем стоп и тейк переворотной позиции.
// TP рассчитывается от реальной цены входа (не от _slPrice) для точного 1:1 R:R.
if enableReversal and strategy.position_size > 0 and strategy.opentrades > 0
    if strategy.opentrades.entry_id(0) == "Rev Buy"
        _revEntryPrice = strategy.opentrades.entry_price(0)
        _revTP         = _revEntryPrice + (_revEntryPrice - revSLLevel)
        strategy.exit("Rev Buy Exit", "Rev Buy",
             stop = revSLLevel, limit = _revTP,
             comment_loss = "Rev SL", comment_profit = "Rev TP")

if enableReversal and strategy.position_size < 0 and strategy.opentrades > 0
    if strategy.opentrades.entry_id(0) == "Rev Sell"
        _revEntryPrice = strategy.opentrades.entry_price(0)
        _revTP         = _revEntryPrice - (revSLLevel - _revEntryPrice)
        strategy.exit("Rev Sell Exit", "Rev Sell",
             stop = revSLLevel, limit = _revTP,
             comment_loss = "Rev SL", comment_profit = "Rev TP")

// ─────────────────────────────────────────────────────────────────────────────
// Визуализация сигналов на ценовом графике
// ─────────────────────────────────────────────────────────────────────────────
plotshape(strongSell, title = "Sell Signal", style = shape.triangledown,
     location = location.abovebar, color = color.red,
     size = size.small, offset = -2)

plotshape(strongBuy, title = "Buy Signal", style = shape.triangleup,
     location = location.belowbar, color = color.green,
     size = size.small, offset = -2)

// Уровни отложенного ордера и стопа (пока нет позиции)
plot(pendingSell and strategy.position_size == 0 ? pendingEntry : na,
     "Pending Sell Entry", color = color.red,   style = plot.style_linebr, linewidth = 1)
plot(pendingSell and strategy.position_size == 0 ? pendingStop  : na,
     "Pending Sell Stop",  color = color.red,   style = plot.style_linebr, linewidth = 1)

plot(pendingBuy and strategy.position_size == 0 ? pendingEntry : na,
     "Pending Buy Entry",  color = color.green, style = plot.style_linebr, linewidth = 1)
plot(pendingBuy and strategy.position_size == 0 ? pendingStop  : na,
     "Pending Buy Stop",   color = color.green, style = plot.style_linebr, linewidth = 1)

// Реальный зафиксированный стоп (устанавливается на баре входа, может отличаться от pendingStop)
plot(strategy.position_size != 0 and not na(fixedStop) ? fixedStop : na,
     "Active Stop", color = color.orange, style = plot.style_linebr, linewidth = 2)
